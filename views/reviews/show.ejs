<% layout('layout') %>

<h2><%= book.title %></h2>

<ul class="list-group">
<li class="list-group-item">Author: <%= book.author %></li>
<li class="list-group-item">Genre: <%= book.genre %></li>
<li class="list-group-item">Published: <%= book.publishedDate %></li>
<li class="list-group-item">Rating: <%= book.rating %></li>
<li class="list-group-item">Review: <%= book.review %></li>
<li class="list-group-item">Review Date: <%= book.reviewDate.toISOString().split('T')[0] %></li>
</ul>

<br>

<a href="/books/<%= book._id %>/edit" class="btn btn-warning">Edit</a>

<form method="POST" action="/books/<%= book._id %>?_method=DELETE">
<button class="btn btn-danger mt-2">Delete</button>
</form>